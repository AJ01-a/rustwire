  "tldr": [
    {
      "source": "hackernews",
      "subsource": "news.ycombinator.com",
      "category": "ai",
      "title": "Anthropic's open-source framework for AI-powered vulnerability discovery",
      "url": "https://github.com/anthropics/defending-code-reference-harness",
      "discuss_url": "https://news.ycombinator.com/item?id=48403980",
      "score": 422,
      "comments": 119,
      "author": "binyu",
      "published": "2026-06-04T20:11:20Z",
      "bullets": [
        "The release enables security teams to benchmark LLMs like Claude 3.5 Sonnet on automated software exploitation and patching tasks.",
        "It utilizes agentic scaffolding, letting AI models run terminal commands, compilers, and debuggers inside secure Docker containers.",
        "This standardized testing harness helps AI safety researchers measure cyber-capabilities and establish risk-mitigation guardrails for autonomous agents."
      ]
    },
    {
      "source": "lobsters",
      "subsource": "lobste.rs/programming",
      "category": "engineering",
      "title": "Navigating the Fog of War: Age of Empires, AI Agents, and the Rise of Dark Code",
      "url": "https://blog.waleson.com/2026/05/navigating-fog-of-war-age-of-empires-ai.html",
      "discuss_url": "https://lobste.rs/s/huexha",
      "score": 2,
      "comments": 2,
      "author": "j11g",
      "published": "2026-06-05T05:29:28Z",
      "bullets": [
        "RTS games like Age of Empires serve as critical training environments for AI agents navigating partially observable, real-time state spaces.",
        "Dark code represents unmonitored, emergent, or AI-generated executable logic operating outside traditional CI/CD pipelines and static analysis tools.",
        "Mitigating agentic risks requires runtime observability, strict execution sandboxing, and policy-enforcing guardrails for autonomous code generation."
      ]
    },
    {
      "source": "lobsters",
      "subsource": "lobste.rs/security",
      "category": "security",
      "title": "Pwnd Blaster: Hacking your PC using your speaker without ever touching it",
      "url": "https://blog.nns.ee/2026/06/03/katana-badusb/",
      "discuss_url": "https://lobste.rs/s/mth4mj",
      "score": 50,
      "comments": 5,
      "author": "matthew2",
      "published": "2026-06-03T11:54:11Z",
      "bullets": [
        "Acoustic attacks exploit speaker hardware, turning output transducers into makeshift microphones to silently capture sensitive nearby ambient audio.",
        "Attackers can use ultrasonic frequencies to inject commands into voice control systems or disrupt hard drives through physical resonance.",
        "Mitigate risks by physically disconnecting unused speakers, shielding hardware from electromagnetic interference, and auditing audio driver capabilities."
      ]
    },
