  "tldr": [
    {
      "source": "lobsters",
      "subsource": "lobste.rs/ai",
      "category": "ai",
      "title": "Investigating idiosyncrasies in AI fiction",
      "url": "https://arxiv.org/abs/2604.03136",
      "discuss_url": "https://lobste.rs/s/hjuopb",
      "score": 4,
      "comments": 2,
      "author": "kehn",
      "published": "2026-07-02T12:02:29Z",
      "bullets": [
        "LLMs exhibit distinct stylistic tells in fiction, such as overusing specific vocabulary ('tapestry', 'beacon') and predictable narrative pacing.",
        "RLHF and alignment tuning restrict narrative tension, forcing models toward sanitized, cliché, and universally positive story resolutions.",
        "Analysts use perplexity, burstiness, and n-gram frequency analysis to differentiate AI-generated creative prose from human-written fiction."
      ]
    },
    {
      "source": "lobsters",
      "subsource": "lobste.rs/programming",
      "category": "engineering",
      "title": "If you’re a button, you have one job",
      "url": "https://unsung.aresluna.org/if-youre-a-button-you-have-one-job/",
