  "tldr": [
    {
      "source": "hackernews",
      "subsource": "news.ycombinator.com",
      "category": "ai",
      "title": "I tricked Claude into leaking your deepest, darkest secrets",
      "url": "https://www.ayush.digital/blog/the-memory-heist",
      "discuss_url": "https://news.ycombinator.com/item?id=48916975",
      "score": 172,
      "comments": 67,
      "author": "macleginn",
      "published": "2026-07-15T06:28:00Z",
      "bullets": [
        "Indirect prompt injection exploits Anthropic Claude's alignment, enabling attackers to exfiltrate system instructions and user data from active sessions.",
        "Shared context environments, like Claude Projects, are vulnerable to cross-session data leaks when processing untrusted third-party documents.",
        "Defend LLM applications by enforcing hard boundaries between system instructions, user inputs, and retrieved external data."
      ]
    },
    {
      "source": "lobsters",
      "subsource": "lobste.rs/programming",
      "category": "engineering",
      "title": "Empathy and delight mean nothing when the software is disrespectful",
      "url": "https://productpicnic.beehiiv.com/p/empathy-and-delight-mean-nothing-when-the-software-is-disrespectful",
      "discuss_url": "https://lobste.rs/s/s4qbwh",
      "score": 4,
      "comments": 0,
      "author": "drmorr",
      "published": "2026-07-15T04:30:14Z",
      "bullets": [
        "Respectful engineering prioritizes resource efficiency, minimizing CPU, memory, and battery drain over bloated Electron wrappers or heavy client-side frameworks.",
        "Prioritize user agency by respecting system-level configurations, offline-first architectures, and opt-in telemetry rather than intrusive, forced data collection.",
        "Eliminate dark patterns and disruptive forced updates; focus on predictable API versioning, stable configurations, and preserving user workflow continuity."
      ]
    },
    {
      "source": "hackernews",
      "subsource": "news.ycombinator.com",
      "category": "security",
      "title": "Cursor 0day: When Full Disclosure Becomes the Only Protection Left",
      "url": "https://mindgard.ai/blog/cursor-0day-when-full-disclosure-becomes-the-only-protection-left",
      "discuss_url": "https://news.ycombinator.com/item?id=48910676",
      "score": 345,
      "comments": 160,
      "author": "Synthetic7346",
      "published": "2026-07-14T17:58:35Z",
      "bullets": [
        "An unpatched zero-day in the Cursor AI editor (VS Code fork) allows Remote Code Execution (RCE) via malicious workspaces.",
        "Attackers can exploit malicious repositories or configuration files like '.cursorrules' to compromise developer machines running the IDE.",
        "Security teams must enforce workspace trust controls and monitor developer endpoints for unauthorized AI editor installations."
      ]
    },
    {
      "source": "rss",
      "subsource": "aws.amazon.com",
      "category": "devops",
      "title": "AWS Elastic Disaster Recovery now supports Amazon EBS volume initialization rate",
      "url": "https://aws.amazon.com/about-aws/whats-new/2026/07/aws-drs-fast-hydration/",
      "discuss_url": "https://aws.amazon.com/about-aws/whats-new/2026/07/aws-drs-fast-hydration/",
      "score": null,
      "comments": null,
      "author": "aws@amazon.com",
      "published": "2026-07-14T22:00:56Z",
      "bullets": [
        "AWS DRS now supports EBS volume initialization rates, accelerating S3 background data loading to reach full storage performance faster during recoveries.",
        "Configure the rate once in the DRS-managed EC2 launch template; AWS automatically preserves this setting during rightsizing and disk updates.",
        "To prevent blocked recovery pipelines, DRS automatically falls back and completes volume recovery if the initialization rate cannot be applied."
      ]
    },
    {
      "source": "rss",
      "subsource": "arstechnica.com",
      "category": "industry",
      "title": "Microsoft’s Secure Boot has been broken for a decade and no one noticed until now",
      "url": "https://arstechnica.com/security/2026/07/microsoft-secure-boot-has-been-broken-for-most-of-its-existence/",
      "discuss_url": "https://arstechnica.com/security/2026/07/microsoft-secure-boot-has-been-broken-for-most-of-its-existence/",
      "score": null,
      "comments": null,
      "author": "Dan Goodin",
      "published": "2026-07-14T22:20:48Z",
      "bullets": [
        "Microsoft failed to revoke old UEFI shim bootloaders, leaving a decade-long window for attackers to trivially bypass Secure Boot protections.",
        "The vulnerability allows threat actors to leverage historically signed, unrevoked shims to execute unauthorized bootkits and compromise the OS.",
        "Security teams should ensure UEFI revocation lists (DBX) are actively updated to block these vulnerable legacy bootloaders."
      ]
    }
