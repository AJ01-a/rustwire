  "tldr": [
    {
      "source": "lobsters",
      "subsource": "lobste.rs/ai",
      "category": "ai",
      "title": "What does it mean to be a mathematician when AI does the math?",
      "url": "https://spectrum.ieee.org/ai-in-mathematics",
      "discuss_url": "https://lobste.rs/s/hvd5hk",
      "score": 9,
      "comments": 7,
      "author": "veqq",
      "published": "2026-06-27T00:27:42Z",
      "bullets": [
        "AI systems like Google DeepMind's AlphaProof and AlphaGeometry are shifting mathematics from manual proof generation to automated theorem proving.",
        "Mathematicians increasingly use formal verification languages like Lean 4 to verify AI-generated proofs and collaborate with neural network systems.",
        "For AI practitioners, the frontier is combining LLMs with reinforcement learning and symbolic solvers to achieve verifiable reasoning, not just heuristics."
      ]
    },
    {
      "source": "lobsters",
      "subsource": "lobste.rs/programming",
      "category": "engineering",
      "title": "Text files as a user interface",
      "url": "https://ratfactor.com/cards/text-files-as-ui",
      "discuss_url": "https://lobste.rs/s/u1clgf",
      "score": 17,
      "comments": 1,
      "author": "sloanelybutsurely",
      "published": "2026-06-27T03:56:22Z",
      "bullets": [
        "Plain text interfaces enable seamless version control via Git, providing native history, diffs, and audit trails for application state.",
        "Storing data in YAML or Markdown allows developers to manipulate application state using CLI tools like grep, jq, and awk.",
        "Text-based UIs power robust engineering workflows, including GitOps, ledger-based accounting, and local-first knowledge management systems."
      ]
    },
    {
      "source": "lobsters",
