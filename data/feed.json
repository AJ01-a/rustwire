  "tldr": [
    {
      "source": "hackernews",
      "subsource": "news.ycombinator.com",
      "category": "ai",
      "title": "Claude is not your architect. Stop letting it pretend",
      "url": "https://www.hollandtech.net/claude-is-not-your-architect/",
      "discuss_url": "https://news.ycombinator.com/item?id=48259784",
      "score": 251,
      "comments": 177,
      "author": "cdrnsf",
      "published": "2026-05-24T18:28:11Z",
      "bullets": [
        "LLMs like Claude lack systemic reasoning, generating plausible-looking but structurally flawed software architectures that fail under production scale.",
        "AI-generated designs often suffer from hallucinated dependencies, outdated API patterns, and silent failure modes that humans must painstakingly debug.",
        "Use LLMs for local code generation and brainstorming, but rely on human architects to define distributed systems and boundaries."
      ]
    },
    {
      "source": "lobsters",
      "subsource": "lobste.rs/programming",
      "category": "engineering",
      "title": "The Eternal Sloptember",
      "url": "https://geohot.github.io//blog/jekyll/update/2026/05/24/the-eternal-sloptember.html",
